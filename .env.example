# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://screendex_user:screendex_pass@localhost:5432/screendex_db
DATABASE_URL_SYNC=postgresql://screendex_user:screendex_pass@localhost:5432/screendex_db

# ─── Storage ───────────────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
MAX_UPLOAD_SIZE_MB=20

# ─── OCR ──────────────────────────────────────────────────────────────────────
# Primary OCR engine: "easyocr" | "tesseract" | "both"
OCR_ENGINE=both
# Confidence threshold below which a result is considered low-quality (0.0–1.0)
OCR_CONFIDENCE_THRESHOLD=0.4
# EasyOCR languages (comma-separated)
EASYOCR_LANGUAGES=en

# ─── EAST Text Detection ───────────────────────────────────────────────────────
# Path to EAST frozen model (download separately — see README)
EAST_MODEL_PATH=models/frozen_east_text_detection.pb
EAST_CONFIDENCE_THRESHOLD=0.5
EAST_NMS_THRESHOLD=0.4

# ─── Semantic Search ──────────────────────────────────────────────────────────
# HuggingFace sentence-transformers model name
SENTENCE_TRANSFORMER_MODEL=all-MiniLM-L6-v2
# Semantic similarity threshold for results (0.0–1.0)
SEMANTIC_THRESHOLD=0.3

# ─── App ──────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=change-this-in-production
